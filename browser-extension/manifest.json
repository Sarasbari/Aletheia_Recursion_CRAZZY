{
  "manifest_version": 3,
  "name": "Aletheia",
  "description": "Analyze webpage images for AI probability and verification status.",
  "version": "1.0.0",
  "action": {
    "default_title": "Aletheia",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
