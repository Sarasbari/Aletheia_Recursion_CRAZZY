{
  "manifest_version": 3,
  "name": "Aletheia Basic Extension",
  "description": "A minimal browser extension starter with popup, background worker, and content script.",
  "version": "0.1.0",
  "action": {
    "default_title": "Aletheia",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
